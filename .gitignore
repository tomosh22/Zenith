# Ignore all Assets directories
**/Assets/

# Accidental Windows NUL device redirections
/nul
**/nul

# Generated complexity analysis outputs (regenerated by Tools/RunAnalysis.bat)
complexity_report/*.json
complexity_report/*.csv
complexity_report/*.html
complexity_report/*.md
complexity_report/*.sarif
complexity_report/llm_cache.json

# Generated CI complexity analysis output (regenerated by Tools/CheckComplexity.bat)
complexity_report_ci/

# Android build outputs
*.apk
Games/TilePuzzle/Android/app/build/

# ImGui layout persistence lives outside the repo (%LOCALAPPDATA%/Zenith/<GameName>/imgui.ini);
# the in-repo default layout is code-built (Zenith_Editor's DockBuilder pass).
imgui.ini

# Brush-indicator decal textures are regenerated at every editor boot
# (Zenith_TerrainEditor::RegenerateBrushTextures).
Zenith/Assets/Textures/Brushes/

# Telemetry kill-safe test artifact (Zenith_Telemetry.Tests.inl writes this into the
# CWD). Narrow to the exact filename so it does NOT shadow the tracked
# Build/dp_telemetry/seed_matrix/*.telemetry.ztlm baselines.
ztlm_flushsnapshot_test.ztlm

# Per-run DevilsPlayground automated-test report artifacts (regenerated by
# Tools/run_dp_tests.ps1 on every run).
Build/dp_test_results/

# --- Descriptor-driven per-game build system (generated artifacts) ---
# Codegen output: per-game project+solution CLR shells + SHA manifest, emitted
# from Games/<Name>/<Name>.zproj by Build/zenith_buildsystem.psm1 on every regen.
Build/Sharpmake_GameInstances.generated.cs
# Per-game solutions live at the game root (Sokoban_win64.sln / Sokoban_agde.sln),
# generated by Build/regen.ps1 -- never committed (Unity/Unreal model).
Games/*/*.sln
# Engine-only solution (engine libs + Sentinels + tools + hub, zero games).
Build/zenith_engine_win64.sln
# ZenithHub launcher build artifacts (its output/ is not under a Build/ dir).
ZenithHub/output/
