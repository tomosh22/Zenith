# Catch project-root obj/ dirs (e.g. TilePuzzleLevelGen/obj, TilePuzzleRegistryViewer/obj)
# whose FileListAbsolute.txt files contain machine-local absolute paths.
**/obj/
# Per-session Claude worktrees should stay local
.claude/worktrees/
# Per-session scheduled-task lock (harness state, not a code artifact)
.claude/scheduled_tasks.lock
/*vs/*
.vs/
/Middleware/VulkanSDK/1.4.313.1/Lib/*
/Middleware/VulkanSDK/1.4.313.1/Bin/*
/Middleware/VulkanSDK/1.4.313.1/Bin32/*
/Middleware/VulkanSDK/1.4.313.1/cmake/*
/Middleware/VulkanSDK/1.4.313.1/Config/*
/Middleware/VulkanSDK/1.4.313.1/Demos/*
/Middleware/VulkanSDK/1.4.313.1/installerResources/*
/Middleware/VulkanSDK/1.4.313.1/Lib32/*
/Middleware/VulkanSDK/1.4.313.1/share/*
