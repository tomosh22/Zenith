# Android build outputs
*.apk
Games/TilePuzzle/Android/app/build/

# ImGui layout persistence lives outside the repo (%LOCALAPPDATA%/Zenith/<GameName>/imgui.ini);
# the in-repo default layout is code-built (Zenith_Editor's DockBuilder pass).
imgui.ini

# Brush-indicator decal textures are regenerated at every editor boot
# (Zenith_TerrainEditor::RegenerateBrushTextures).
Zenith/Assets/Textures/Brushes/

# Telemetry kill-safe test artifact (Zenith_Telemetry.Tests.inl writes this into
# the CWD).
ztlm_flushsnapshot_test.ztlm

# --- Descriptor-driven per-game build system (generated artifacts) ---
# Regenerate-first policy: NOTHING Sharpmake emits is committed. Fresh clone or
# branch switch => run Build/regen.ps1 (or `zenith regen`). Hand-written files
# under Build/ (Sharpmake_*.cs, *.ps1/*.psm1/*.bat, Templates/, Tests/, TestData/)
# stay tracked -- "*" does not cross "/" in .gitignore, so the /Build/* rules
# below cannot reach into those subdirectories.
Build/Sharpmake_GameInstances.generated.cs
Games/*/*.sln
/Build/*.sln
/Build/*.vcxproj
/Build/*.vcxproj.filters
/Build/*.vcxproj.user
Games/*/Build/
Games/*/build/
/FluxCompiler/*.vcxproj*
/fluxcompiler_win64.vcxproj*
/TilePuzzleLevelGen/*.vcxproj*
/TilePuzzleRegistryViewer/*.vcxproj*
/ZenithHub/*.vcxproj*
# Third-party font-lib MSBuild intermediates that land under Build/<Lib>/
/Build/FreeType/
/Build/msdfgen/
/Build/msdf-atlas-gen/
/Games/TilePuzzle/Android/build/
# ZenithHub launcher build artifacts (its output/ is not under a Build/ dir).
ZenithHub/output/

# --- Canonical untracked artifact root: test results, telemetry, logs, packages.
# All runner scripts write under Build/artifacts/ (see AGENTS.md); never commit it.
/Build/artifacts/
/dist/

# --- Run residue at the Build/ root (stray logs from ad-hoc redirects, temp
# session markers, engine data drops). All sanctioned outputs live under
# Build/artifacts/ above; these rules just keep accidents out of the index. ---
/Build/*.log
/Build/*.txt
/Build/*.err
/Build/*.dat
/Build/tmpclaude-*
# Engine unit test writes this into the exe CWD (Zenith_UnitTests.Tests.inl).
unit_test_scene.zscen
# Local tool scratch dirs at repo root
/.codex_tmp/
