# zenith_buildsystem.psm1
# =============================================================================
# Single source of truth for the Zenith descriptor-driven per-game build system.
#
#   * Scans   Games/<Name>/<Name>.zproj descriptors.
#   * Validates them (name syntax, schema, key allow-list, android/dir coherence,
#     duplicate detection) -- collecting ALL errors, never fail-fast.
#   * Generates Build/Sharpmake_GameInstances.generated.cs (the per-game project +
#     solution CLR shells + a SHA256 manifest guard) consumed by Sharpmake.
#
# Game-name validation lives ONLY here; the CLI (Tools/ZenithCli) imports this
# module, and the C++ hub self-test mirrors the rules against the shared vector
# file Tools/ZenithCli/Tests/name_validation_cases.txt.
#
# ASCII-only body, no PowerShell 7-only syntax (ternary/null-coalescing), so both
# Windows PowerShell 5.1 and pwsh 7 parse and run it identically.
# =============================================================================

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

# --- Constants ---------------------------------------------------------------

# Game name: PascalCase, leading uppercase ASCII letter, up to 64 chars total,
# ASCII alphanumeric only. Anchored. Matched case-SENSITIVELY (-cmatch).
$script:ZenithGameNameRegex = '^[A-Z][A-Za-z0-9]{0,63}$'

# The only keys a descriptor may contain. Anything else is a hard error (a typo
# net -- 'extraDefine' or 'andriod' must not silently no-op).
$script:ZenithDescriptorKeys = @('schemaVersion', 'name', 'android', 'extraDefines', 'extraSharpmakeProjects')

# Highest schemaVersion this tool understands. A descriptor above this is a hard
# error (forward descriptors must not be silently mis-generated by an old tool).
$script:ZenithMaxSchemaVersion = 1

# Windows reserved device names (case-insensitive). These satisfy the name regex
# but cannot be used as directory names on Windows.
$script:ZenithReservedDeviceNames = @(
    'CON', 'PRN', 'AUX', 'NUL',
    'COM1', 'COM2', 'COM3', 'COM4', 'COM5', 'COM6', 'COM7', 'COM8', 'COM9',
    'LPT1', 'LPT2', 'LPT3', 'LPT4', 'LPT5', 'LPT6', 'LPT7', 'LPT8', 'LPT9'
)

# Exact engine/tool project names a game must not collide with (case-insensitive).
# The Zenith* and Sentinel* prefixes are additionally reserved by pattern below.
$script:ZenithReservedProjectNames = @(
    'FluxCompiler', 'FreeType', 'Msdfgen', 'MsdfAtlasGen',
    'TilePuzzleLevelGen', 'TilePuzzleRegistryViewer', 'ZenithHub'
)

# --- Paths -------------------------------------------------------------------

function Get-ZenithRepoRoot {
    # The module lives in <root>/Build; the repo root is its parent.
    [CmdletBinding()]
    param()
    return (Split-Path -Parent $PSScriptRoot)
}

# --- Name validation ---------------------------------------------------------

function Test-ZenithGameNameSyntax {
    # Intrinsic name rules only (regex + reserved device names + reserved project
    # names/prefixes). Filesystem collision is a separate concern
    # (Test-ZenithNewGameName). Returns a [string[]] of errors; empty == valid.
    [CmdletBinding()]
    [OutputType([string[]])]
    param([Parameter(Mandatory)][AllowEmptyString()][string]$Name)

    $errs = New-Object System.Collections.Generic.List[string]

    if ([string]::IsNullOrEmpty($Name)) {
        $errs.Add("name is empty")
        return $errs.ToArray()
    }

    if ($Name -cnotmatch $script:ZenithGameNameRegex) {
        $errs.Add("name '$Name' must match $($script:ZenithGameNameRegex) (PascalCase: leading uppercase letter, ASCII alphanumeric, <= 64 chars)")
    }

    $upper = $Name.ToUpperInvariant()

    if ($script:ZenithReservedDeviceNames -contains $upper) {
        $errs.Add("name '$Name' is a reserved Windows device name")
    }

    if ($upper.StartsWith('ZENITH') -or $upper.StartsWith('SENTINEL')) {
        $errs.Add("name '$Name' uses a reserved engine prefix (Zenith*/Sentinel*)")
    }

    foreach ($reserved in $script:ZenithReservedProjectNames) {
        if ($reserved.ToUpperInvariant() -eq $upper) {
            $errs.Add("name '$Name' collides with reserved project '$reserved'")
        }
    }

    return $errs.ToArray()
}

function Test-ZenithNewGameName {
    # Syntax rules PLUS case-insensitive collision against existing Games/* dirs.
    # Used by `zenith new`. Returns a [string[]] of errors; empty == valid.
    [CmdletBinding()]
    [OutputType([string[]])]
    param(
        [Parameter(Mandatory)][AllowEmptyString()][string]$Name,
        [string]$GamesRoot
    )

    $errs = New-Object System.Collections.Generic.List[string]
    foreach ($e in (Test-ZenithGameNameSyntax -Name $Name)) { $errs.Add($e) }

    if ([string]::IsNullOrEmpty($GamesRoot)) {
        $GamesRoot = Join-Path (Get-ZenithRepoRoot) 'Games'
    }
    if (Test-Path -LiteralPath $GamesRoot) {
        $upper = if ([string]::IsNullOrEmpty($Name)) { '' } else { $Name.ToUpperInvariant() }
        foreach ($dir in (Get-ChildItem -LiteralPath $GamesRoot -Directory)) {
            if ($dir.Name.ToUpperInvariant() -eq $upper -and $upper -ne '') {
                $errs.Add("a game folder '$($dir.Name)' already exists (case-insensitive match for '$Name')")
            }
        }
    }

    return $errs.ToArray()
}

# --- Descriptor parse + validate ---------------------------------------------

function Read-ZenithDescriptor {
    # Parse and validate a single .zproj. Never throws on invalid content;
    # collects every problem into .Errors. .Ok is $true iff .Errors is empty.
    [CmdletBinding()]
    param([Parameter(Mandatory)][string]$Path)

    $errs = New-Object System.Collections.Generic.List[string]
    $name = $null
    $android = $false
    $extraDefines = @()
    $extraProjects = @()

    if (-not (Test-Path -LiteralPath $Path)) {
        $errs.Add("descriptor not found: $Path")
        return (New-ZenithDescriptorResult -Path $Path -Name $name -Android $android -ExtraDefines $extraDefines -ExtraProjects $extraProjects -Errors $errs)
    }

    $folder = Split-Path -Parent $Path
    $folderName = Split-Path -Leaf $folder
    $basename = [System.IO.Path]::GetFileNameWithoutExtension($Path)

    $raw = Get-Content -LiteralPath $Path -Raw
    $json = $null
    try {
        $json = $raw | ConvertFrom-Json
    }
    catch {
        $errs.Add("descriptor '$Path' is not valid JSON: $($_.Exception.Message)")
        return (New-ZenithDescriptorResult -Path $Path -Name $name -Android $android -ExtraDefines $extraDefines -ExtraProjects $extraProjects -Errors $errs)
    }

    if ($null -eq $json -or $json -isnot [System.Management.Automation.PSCustomObject]) {
        $errs.Add("descriptor '$Path' must be a JSON object")
        return (New-ZenithDescriptorResult -Path $Path -Name $name -Android $android -ExtraDefines $extraDefines -ExtraProjects $extraProjects -Errors $errs)
    }

    $presentKeys = @($json.PSObject.Properties.Name)

    # Unknown-key net.
    foreach ($k in $presentKeys) {
        if ($script:ZenithDescriptorKeys -notcontains $k) {
            $errs.Add("descriptor '$Path' has unknown key '$k' (allowed: $($script:ZenithDescriptorKeys -join ', '))")
        }
    }

    # schemaVersion (required).
    if ($presentKeys -notcontains 'schemaVersion') {
        $errs.Add("descriptor '$Path' is missing required key 'schemaVersion'")
    }
    else {
        $sv = $json.schemaVersion
        $svIsNumber = ($sv -is [int] -or $sv -is [long] -or $sv -is [double] -or $sv -is [decimal])
        if (-not $svIsNumber) {
            $errs.Add("descriptor '$Path' schemaVersion must be an integer number")
        }
        elseif ([double]$sv -ne [math]::Floor([double]$sv)) {
            $errs.Add("descriptor '$Path' schemaVersion must be an integer (got $sv)")
        }
        elseif ([int]$sv -lt 1 -or [int]$sv -gt $script:ZenithMaxSchemaVersion) {
            $errs.Add("descriptor '$Path' has unsupported schemaVersion $sv (this tool supports 1..$($script:ZenithMaxSchemaVersion))")
        }
    }

    # name (required).
    if ($presentKeys -notcontains 'name') {
        $errs.Add("descriptor '$Path' is missing required key 'name'")
    }
    else {
        $nm = $json.name
        if ($nm -isnot [string]) {
            $errs.Add("descriptor '$Path' name must be a string")
        }
        else {
            $name = $nm
            foreach ($e in (Test-ZenithGameNameSyntax -Name $nm)) { $errs.Add($e) }
            if ($nm -cne $folderName) {
                $errs.Add("descriptor '$Path' name '$nm' must equal its folder name '$folderName'")
            }
            if ($nm -cne $basename) {
                $errs.Add("descriptor '$Path' name '$nm' must equal its file basename '$basename'")
            }
        }
    }

    # android (optional, default false).
    if ($presentKeys -contains 'android') {
        if ($json.android -isnot [bool]) {
            $errs.Add("descriptor '$Path' android must be a boolean")
        }
        else {
            $android = [bool]$json.android
        }
    }

    # android:true requires an Android/ dir in the game folder (the Gradle tree).
    if ($android) {
        $androidDir = Join-Path $folder 'Android'
        if (-not (Test-Path -LiteralPath $androidDir)) {
            $errs.Add("descriptor '$Path' sets android:true but '$androidDir' does not exist")
        }
    }

    # extraDefines (optional array of strings).
    if ($presentKeys -contains 'extraDefines') {
        $arr = @($json.extraDefines)
        $bad = $false
        foreach ($item in $arr) { if ($item -isnot [string]) { $bad = $true } }
        if ($bad) { $errs.Add("descriptor '$Path' extraDefines must be an array of strings") }
        else { $extraDefines = $arr }
    }

    # extraSharpmakeProjects (optional array of strings).
    if ($presentKeys -contains 'extraSharpmakeProjects') {
        $arr = @($json.extraSharpmakeProjects)
        $bad = $false
        foreach ($item in $arr) { if ($item -isnot [string]) { $bad = $true } }
        if ($bad) { $errs.Add("descriptor '$Path' extraSharpmakeProjects must be an array of strings") }
        else { $extraProjects = $arr }
    }

    return (New-ZenithDescriptorResult -Path $Path -Name $name -Android $android -ExtraDefines $extraDefines -ExtraProjects $extraProjects -Errors $errs)
}

function New-ZenithDescriptorResult {
    # Internal helper: assemble the descriptor result object uniformly.
    [CmdletBinding()]
    param(
        [string]$Path,
        [object]$Name,
        [bool]$Android,
        [object]$ExtraDefines,
        [object]$ExtraProjects,
        [object]$Errors
    )
    $errArray = @($Errors)
    return [PSCustomObject]@{
        Ok                     = ($errArray.Count -eq 0)
        Path                   = $Path
        Name                   = $Name
        Android                = $Android
        ExtraDefines           = @($ExtraDefines)
        ExtraSharpmakeProjects = @($ExtraProjects)
        Errors                 = $errArray
    }
}

function Get-ZenithGameDescriptors {
    # Scan every Games/<Name>/ folder for exactly one .zproj, parse+validate each,
    # and cross-check for duplicate names. Returns { Descriptors; Errors } with ALL
    # errors aggregated (fixture-friendly: point -GamesRoot at a test tree).
    [CmdletBinding()]
    param([string]$GamesRoot)

    if ([string]::IsNullOrEmpty($GamesRoot)) {
        $GamesRoot = Join-Path (Get-ZenithRepoRoot) 'Games'
    }

    $errs = New-Object System.Collections.Generic.List[string]
    $descriptors = New-Object System.Collections.Generic.List[object]

    if (-not (Test-Path -LiteralPath $GamesRoot)) {
        $errs.Add("Games root not found: $GamesRoot")
        return [PSCustomObject]@{ Descriptors = @(); Errors = $errs.ToArray() }
    }

    $gameDirs = Get-ChildItem -LiteralPath $GamesRoot -Directory | Sort-Object Name
    foreach ($dir in $gameDirs) {
        $zprojs = @(Get-ChildItem -LiteralPath $dir.FullName -Filter '*.zproj' -File -ErrorAction SilentlyContinue)
        if ($zprojs.Count -eq 0) {
            $errs.Add("game folder '$($dir.Name)' has no .zproj descriptor")
            continue
        }
        if ($zprojs.Count -gt 1) {
            $names = ($zprojs | ForEach-Object { $_.Name }) -join ', '
            $errs.Add("game folder '$($dir.Name)' has $($zprojs.Count) .zproj descriptors (expected exactly 1): $names")
            continue
        }
        $desc = Read-ZenithDescriptor -Path $zprojs[0].FullName
        foreach ($e in $desc.Errors) { $errs.Add($e) }
        $descriptors.Add($desc)
    }

    # Duplicate-name detection (case-insensitive) across folders.
    $seen = @{}
    foreach ($d in $descriptors) {
        if ($null -eq $d.Name) { continue }
        $key = ([string]$d.Name).ToUpperInvariant()
        if ($seen.ContainsKey($key)) {
            $errs.Add("duplicate game name '$($d.Name)' in '$($d.Path)' and '$($seen[$key])'")
        }
        else {
            $seen[$key] = $d.Path
        }
    }

    return [PSCustomObject]@{ Descriptors = @($descriptors.ToArray()); Errors = $errs.ToArray() }
}

# --- Codegen -----------------------------------------------------------------

function Invoke-ZenithCodegen {
    # Emit Build/Sharpmake_GameInstances.generated.cs from validated descriptors.
    # Throws if validation fails (a broken descriptor must never yield a broken
    # generated file). Returns the emitted text (also written to -OutputPath unless
    # -OutputPath is the empty string).
    [CmdletBinding()]
    param(
        [string]$GamesRoot,
        [string]$OutputPath,
        [object[]]$Descriptors
    )

    $repoRoot = Get-ZenithRepoRoot
    if ([string]::IsNullOrEmpty($GamesRoot)) { $GamesRoot = Join-Path $repoRoot 'Games' }
    if ($null -eq $OutputPath) { $OutputPath = Join-Path $repoRoot 'Build/Sharpmake_GameInstances.generated.cs' }

    if ($null -eq $Descriptors) {
        $scan = Get-ZenithGameDescriptors -GamesRoot $GamesRoot
        if ($scan.Errors.Count -gt 0) {
            throw ("cannot generate Sharpmake_GameInstances.generated.cs: descriptor validation failed:`n  " + ($scan.Errors -join "`n  "))
        }
        $Descriptors = $scan.Descriptors
    }

    # Deterministic order: alphabetical by name (case-insensitive) so the golden
    # file and the SHA manifest are stable regardless of directory enumeration.
    $ordered = @($Descriptors | Sort-Object { ([string]$_.Name).ToUpperInvariant() })

    $nl = "`n"
    $sb = New-Object System.Text.StringBuilder

    [void]$sb.Append("// <auto-generated>$nl")
    [void]$sb.Append("// Generated by Build/zenith_buildsystem.psm1 (Invoke-ZenithCodegen).$nl")
    [void]$sb.Append("// Source of truth: Games/<Name>/<Name>.zproj descriptors.$nl")
    [void]$sb.Append("// DO NOT EDIT BY HAND -- run Build/regen.ps1 to regenerate. This file is gitignored.$nl")
    [void]$sb.Append("// </auto-generated>$nl")
    [void]$sb.Append("using Sharpmake;$nl")
    [void]$sb.Append("using System;$nl")
    [void]$sb.Append($nl)

    foreach ($d in $ordered) {
        $name = [string]$d.Name
        $android = if ($d.Android) { 'true' } else { 'false' }

        # Game project shell (reuses today's class name -> zero GUID churn).
        [void]$sb.Append("[Sharpmake.Generate]$nl")
        [void]$sb.Append("public class ${name}GameProject : GameProject$nl")
        [void]$sb.Append("{$nl")
        [void]$sb.Append("`tpublic override string GameName => `"$name`";$nl")
        [void]$sb.Append("`tpublic override bool HasAndroid => $android;$nl")
        if (@($d.ExtraDefines).Count -gt 0) {
            $defs = (@($d.ExtraDefines) | ForEach-Object { "`"$_`"" }) -join ', '
            [void]$sb.Append("`tpublic override string[] ExtraDefines => new string[] { $defs };$nl")
        }
        [void]$sb.Append("}$nl")
        [void]$sb.Append($nl)

        # Per-game solution shell.
        [void]$sb.Append("[Sharpmake.Generate]$nl")
        [void]$sb.Append("public class ${name}GameSolution : GameSolution$nl")
        [void]$sb.Append("{$nl")
        [void]$sb.Append("`tpublic override string GameName => `"$name`";$nl")
        [void]$sb.Append("`tpublic override bool HasAndroid => $android;$nl")
        [void]$sb.Append("`tpublic override Type GameProjectType => typeof(${name}GameProject);$nl")
        if (@($d.ExtraSharpmakeProjects).Count -gt 0) {
            $projs = (@($d.ExtraSharpmakeProjects) | ForEach-Object { "`"$_`"" }) -join ', '
            [void]$sb.Append("`tpublic override string[] ExtraProjectTypeNames => new string[] { $projs };$nl")
        }
        [void]$sb.Append("}$nl")
        [void]$sb.Append($nl)
    }

    # SHA256 manifest guard. Sharpmake_Solutions.cs re-hashes the on-disk
    # descriptors and compares against this set; any drift => the generated file
    # is stale and it throws asking for a Build/regen.ps1 run.
    [void]$sb.Append("// Manifest guard: (descriptor path, SHA256) per game. Sharpmake_Solutions.cs$nl")
    [void]$sb.Append("// re-hashes the on-disk .zproj files and compares; drift means this file is$nl")
    [void]$sb.Append("// stale relative to the descriptors -> regenerate with Build/regen.ps1.$nl")
    [void]$sb.Append("public static class GeneratedGameManifest$nl")
    [void]$sb.Append("{$nl")
    [void]$sb.Append("`tpublic struct Entry$nl")
    [void]$sb.Append("`t{$nl")
    [void]$sb.Append("`t`tpublic readonly string DescriptorPath;$nl")
    [void]$sb.Append("`t`tpublic readonly string Sha256;$nl")
    [void]$sb.Append("`t`tpublic Entry(string strDescriptorPath, string strSha256) { DescriptorPath = strDescriptorPath; Sha256 = strSha256; }$nl")
    [void]$sb.Append("`t}$nl")
    [void]$sb.Append($nl)
    [void]$sb.Append("`tpublic static readonly Entry[] Entries = new Entry[]$nl")
    [void]$sb.Append("`t{$nl")
    $rrNorm = $repoRoot.Replace('\', '/').TrimEnd('/')
    foreach ($d in $ordered) {
        # Descriptor path relative to repo root, forward slashes. For production
        # games this is exactly "Games/<Name>/<Name>.zproj", which is what the
        # Sharpmake_Solutions.cs guard rebuilds from its own Games/ scan.
        $fp = ([string]$d.Path).Replace('\', '/')
        if ($fp.ToLowerInvariant().StartsWith($rrNorm.ToLowerInvariant() + '/')) {
            $rel = $fp.Substring($rrNorm.Length + 1)
        }
        else {
            $rel = $fp
        }
        $hash = (Get-FileHash -LiteralPath $d.Path -Algorithm SHA256).Hash.ToUpperInvariant()
        [void]$sb.Append("`t`tnew Entry(`"$rel`", `"$hash`"),$nl")
    }
    [void]$sb.Append("`t};$nl")
    [void]$sb.Append("}$nl")

    $text = $sb.ToString()

    if (-not [string]::IsNullOrEmpty($OutputPath)) {
        # WriteAllText with UTF-8 (no BOM) and exactly the LF newlines above, so
        # the on-disk bytes are deterministic across hosts.
        $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
        [System.IO.File]::WriteAllText($OutputPath, $text, $utf8NoBom)
    }

    return $text
}

# --- Worktree guard ----------------------------------------------------------

function Test-ZenithInWorktree {
    # Running Sharpmake from a linked git worktree is a known hazard (it generates
    # into paths that resolve against the wrong tree). A linked worktree's
    # `git rev-parse --git-dir` differs from `--git-common-dir`. Returns $true iff
    # the repo root is a linked worktree. Non-git / errors => $false (don't block).
    [CmdletBinding()]
    param([string]$RepoRoot)

    if ([string]::IsNullOrEmpty($RepoRoot)) { $RepoRoot = Get-ZenithRepoRoot }

    $gitDir = $null
    $commonDir = $null
    try {
        Push-Location $RepoRoot
        $gitDir = (& git rev-parse --git-dir 2>$null)
        $commonDir = (& git rev-parse --git-common-dir 2>$null)
    }
    catch {
        return $false
    }
    finally {
        Pop-Location
    }

    if ([string]::IsNullOrEmpty($gitDir) -or [string]::IsNullOrEmpty($commonDir)) {
        return $false
    }

    # Resolve to absolute paths for a robust comparison; if resolution fails, fall
    # back to the raw string comparison.
    $g = Resolve-Path -LiteralPath $gitDir -ErrorAction SilentlyContinue
    $c = Resolve-Path -LiteralPath $commonDir -ErrorAction SilentlyContinue
    if ($null -ne $g -and $null -ne $c) {
        return ($g.Path -ne $c.Path)
    }
    return ($gitDir -ne $commonDir)
}

# --- Shared name-validation vectors (pins PS + hub validators in lockstep) ----

function Get-ZenithNameValidationCases {
    # Load Tools/ZenithCli/Tests/name_validation_cases.txt: 'expected|name' lines
    # (expected in {valid, invalid}). '#' and blank lines are ignored. The C++ hub
    # self-test parses the same file with the same rules.
    [CmdletBinding()]
    param([string]$Path)

    if ([string]::IsNullOrEmpty($Path)) {
        $Path = Join-Path (Get-ZenithRepoRoot) 'Tools/ZenithCli/Tests/name_validation_cases.txt'
    }
    $cases = New-Object System.Collections.Generic.List[object]
    if (-not (Test-Path -LiteralPath $Path)) { return , $cases.ToArray() }

    foreach ($line in (Get-Content -LiteralPath $Path)) {
        $t = $line
        if ($null -eq $t) { continue }
        if ($t.TrimStart().StartsWith('#')) { continue }
        if ([string]::IsNullOrWhiteSpace($t)) { continue }
        $idx = $t.IndexOf('|')
        if ($idx -lt 0) { continue }
        $expected = $t.Substring(0, $idx).Trim()
        $name = $t.Substring($idx + 1)
        $cases.Add([PSCustomObject]@{ Expected = $expected; Name = $name })
    }
    return $cases.ToArray()
}

Export-ModuleMember -Function @(
    'Get-ZenithRepoRoot',
    'Test-ZenithGameNameSyntax',
    'Test-ZenithNewGameName',
    'Read-ZenithDescriptor',
    'Get-ZenithGameDescriptors',
    'Invoke-ZenithCodegen',
    'Test-ZenithInWorktree',
    'Get-ZenithNameValidationCases'
)
